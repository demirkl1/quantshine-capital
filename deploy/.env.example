# ─────────────────────────────────────────────────────────────────────────────
# QuantShine Production Environment
# Kopyala: cp .env.example .env  → sonra boşlukları doldur.
# UYARI: .env dosyasını ASLA git'e commit etme (.gitignore'da).
# ─────────────────────────────────────────────────────────────────────────────

# ── Domain ──────────────────────────────────────────────────────────────────
# Örnek: quantshine.app
DOMAIN=quantshinecapital.com
LETSENCRYPT_EMAIL=admin@quantshinecapital.com
# İlk testte 1 yap → staging cert (rate-limit yok), doğrulanınca 0 yapıp tekrar çalıştır
LETSENCRYPT_STAGING=0

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=quantshine
# Güçlü bir şifre üret: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Keycloak ────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
# openssl rand -base64 24
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_KEYCLOAK_ADMIN_PW
KEYCLOAK_REALM=quantshine
KEYCLOAK_CLIENT_ID=quantshine-backend

# ── Backend şifreleme anahtarları ───────────────────────────────────────────
# 16+ karakter. openssl rand -base64 24
ENCRYPTION_SECRET=CHANGE_ME_ENCRYPTION_SECRET
# Tam 16 karakter hex (8 byte salt). openssl rand -hex 8
ENCRYPTION_SALT=CHANGE_ME_SALT16

# ── 3rd-party API keys ──────────────────────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_key_here
NEWSAPI_KEY=your_newsapi_key_here
